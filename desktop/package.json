{
  "name": "bioassay-studio-desktop",
  "version": "2.8.1",
  "description": "BioAssay Studio offline scientific data workstation for Windows",
  "main": "main.js",
  "author": "x738",
  "license": "MIT",
  "private": true,
  "scripts": {
    "sync-web": "node tools/sync-web.js",
    "make-icon": "node tools/make-icon.js",
    "prepare": "npm run sync-web && npm run make-icon",
    "start": "npm run prepare && electron .",
    "dist:win": "npm run prepare && electron-builder --win nsis --x64 --publish never"
  },
  "devDependencies": {
    "electron": "43.2.0",
    "electron-builder": "26.15.3",
    "sharp": "0.35.3"
  },
  "build": {
    "appId": "cn.x738.bioassaystudio",
    "productName": "BioAssay Studio",
    "asar": true,
    "compression": "maximum",
    "npmRebuild": false,
    "removePackageScripts": true,
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "main.js",
      "preload.js",
      "package.json",
      "build/icon.png"
    ],
    "extraResources": [
      {
        "from": "web",
        "to": "web",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "icon": "build/icon.png",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "BioAssay-Studio-v${version}-Windows-${arch}-Setup.${ext}"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "x738",
        "repo": "bioassay-studio",
        "releaseType": "release"
      }
    ],
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "BioAssay Studio",
      "deleteAppDataOnUninstall": false,
      "installerLanguages": [
        "zh_CN",
        "en_US"
      ],
      "language": "2052"
    }
  },
  "dependencies": {
    "electron-updater": "6.8.9"
  }
}
